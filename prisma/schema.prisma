generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(OWNER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  businesses   Business[]
  subscriptions Subscription[]
  usageEvents  UsageEvent[]
  googleConnections GoogleConnection[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Business {
  id          String    @id @default(cuid())
  ownerId     String
  name        String
  industry    String
  website     String?
  phone       String?
  address     String?
  defaultTone ReplyTone @default(PROFESSIONAL)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reviews     Review[]
  tasks       Task[]
  usageEvents UsageEvent[]
  googleConnections GoogleConnection[]

  @@index([ownerId])
  @@map("businesses")
}

model Review {
  id            String       @id @default(cuid())
  businessId    String
  source        ReviewSource @default(MANUAL)
  reviewerName  String?
  rating        Int
  content       String
  reviewDate    DateTime?
  sentiment     Sentiment?
  urgency       Urgency?
  needsFollowUp Boolean      @default(false)
  summary       String?
  aiReply       String?
  externalReviewId String?
  externalReviewName String?
  replyPublishedAt DateTime?
  status        ReviewStatus @default(NEW)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@index([businessId])
  @@index([sentiment])
  @@index([status])
  @@unique([businessId, externalReviewName])
  @@map("reviews")
}

model GoogleConnection {
  id                 String   @id @default(cuid())
  userId             String
  businessId         String
  googleAccountName  String?
  googleLocationName String?
  accessToken        String
  refreshToken       String?
  tokenExpiresAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId])
  @@index([userId])
  @@map("google_connections")
}

model Task {
  id          String     @id @default(cuid())
  businessId  String
  reviewId    String?
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  review   Review?  @relation(fields: [reviewId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([reviewId])
  @@index([status])
  @@map("tasks")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model UsageEvent {
  id         String         @id @default(cuid())
  userId     String
  businessId String?
  eventType  UsageEventType
  quantity   Int            @default(1)
  createdAt  DateTime       @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([businessId])
  @@map("usage_events")
}

enum UserRole {
  OWNER
  ADMIN
}

enum ReplyTone {
  FRIENDLY
  PROFESSIONAL
  APOLOGETIC
}

enum ReviewSource {
  MANUAL
  CSV
  GOOGLE
  FACEBOOK
  YELP
  OTHER
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

enum ReviewStatus {
  NEW
  REPLIED
  FOLLOW_UP
  RESOLVED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum UsageEventType {
  AI_REPLY_GENERATED
}
